# Copy to .env on the Jetson and tweak as needed.
# Loaded by systemd via EnvironmentFile= directive.

# Ground station address on the USB-gadget RNDIS network.
# Jetson side is always 192.168.55.1; Windows host is typically .100.
GS_HOST=192.168.55.100
GS_PORT=9001

# Arduino USB-serial device on Jetson.
ARDUINO_PORT=/dev/ttyACM0
ARDUINO_BAUDRATE=115200
